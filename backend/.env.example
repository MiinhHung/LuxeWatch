# Neon PostgreSQL connection string
# Lấy từ: https://console.neon.tech -> Project -> Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# JWT Secret (tự đặt chuỗi bí mật bất kỳ)
JWT_SECRET="your_super_secret_jwt_key_here"

# URL frontend của bạn (điền sau khi deploy frontend lên Vercel)
FRONTEND_URL="https://luxe-watch.vercel.app"

# Port (không cần khi deploy lên Vercel/Render)
PORT=5000
